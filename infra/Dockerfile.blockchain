FROM node:18-alpine

WORKDIR /blockchain

# Install Hardhat and dependencies
RUN npm install -g hardhat @nomicfoundation/hardhat-toolbox

# Copy contract and config
COPY blockchain/ActionAuditLog.sol ./contracts/
COPY blockchain/hardhat.config.js ./
COPY blockchain/deploy.js ./scripts/

# Install dependencies
RUN npm install

# Compile contract
RUN npx hardhat compile

# Start Hardhat node
CMD ["npx", "hardhat", "node", "--hostname", "0.0.0.0"]
